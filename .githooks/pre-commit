#!/usr/bin/env bash
# ============================================================
# 🔒 WeClaw Pre-commit Hook — 敏感信息泄露拦截
# ============================================================
# 阻止真实 API key、密码、token 等敏感信息被提交到 git。
# 安装：git config core.hooksPath .githooks
# ============================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${GREEN}🔒 Running secret detection pre-commit hook...${NC}"

# ── 1. 检测 staged 文件中的真实密钥模式 ──
# 只检查 staged 的 diff 内容（新增行），不检查整个文件
STAGED_DIFF=$(git diff --cached --diff-filter=ACM -U0)

# 定义敏感模式（正则）
# 匹配真实 API key（sk- 开头且长度 ≥ 20 的非占位符）
PATTERNS=(
    'sk-[a-zA-Z0-9]{20,}'                     # OpenAI/DeepSeek style API keys
    'Bearer\s+sk-[a-zA-Z0-9]{20,}'            # Bearer token with real key
    'api_key["\s:=]+["'"'"']sk-[a-zA-Z0-9]{20,}'  # api_key = "sk-..."
    'OPENAI_API_KEY=sk-[a-zA-Z0-9]{20,}'      # env var with real key
    'ghp_[a-zA-Z0-9]{36}'                     # GitHub personal access token
    'gho_[a-zA-Z0-9]{36}'                     # GitHub OAuth token
    'github_pat_[a-zA-Z0-9]{22}_[a-zA-Z0-9]{59}'  # GitHub fine-grained PAT
)

# 已知安全的占位符（白名单），不触发告警
WHITELIST=(
    'sk-xxxxxxxx'
    'sk-xxxxxxxxxxxxxxxx'
    'sk-xxx'
    'sk-abcdef1234567890abcdef1234567890'
    'your_api_key'
    'your_api_key_here'
    'your_secret_token_here'
)

# 额外白名单前缀（匹配以这些开头的值，用于虚构文档示例）
WHITELIST_PREFIXES=(
    'sk-abcdef'
)

FOUND_SECRETS=0

for pattern in "${PATTERNS[@]}"; do
    # 只检查新增的行（以 + 开头的行）
    MATCHES=$(echo "$STAGED_DIFF" | grep -E "^\+" | grep -oE "$pattern" 2>/dev/null || true)
    
    if [ -n "$MATCHES" ]; then
        # 过滤掉白名单
        while IFS= read -r match; do
            IS_WHITELISTED=false
            for safe in "${WHITELIST[@]}"; do
                if [ "$match" = "$safe" ]; then
                    IS_WHITELISTED=true
                    break
                fi
            done
            # 前缀匹配（用于虚构文档示例）
            if [ "$IS_WHITELISTED" = false ]; then
                for prefix in "${WHITELIST_PREFIXES[@]}"; do
                    if [[ "$match" == "$prefix"* ]]; then
                        IS_WHITELISTED=true
                        break
                    fi
                done
            fi
            
            if [ "$IS_WHITELISTED" = false ]; then
                echo -e "${RED}🚨 BLOCKED: Potential secret detected!${NC}"
                echo -e "   Pattern: ${YELLOW}${pattern}${NC}"
                echo -e "   Match:   ${RED}${match:0:8}...${match: -4}${NC} (redacted)"
                echo ""
                FOUND_SECRETS=$((FOUND_SECRETS + 1))
            fi
        done <<< "$MATCHES"
    fi
done

# ── 2. 检测是否有敏感文件被 staged ──
SENSITIVE_FILES=(
    'config/config.yaml'
    '.env'
    '*.pem'
    '*.key'
    'id_rsa'
    'id_ed25519'
)

STAGED_FILES=$(git diff --cached --name-only)

for sensitive in "${SENSITIVE_FILES[@]}"; do
    # 支持通配符匹配
    MATCHED_FILES=$(echo "$STAGED_FILES" | grep -E "^${sensitive//\*/.*}$" 2>/dev/null || true)
    if [ -n "$MATCHED_FILES" ]; then
        echo -e "${RED}🚨 BLOCKED: Sensitive file staged for commit!${NC}"
        echo -e "   File: ${YELLOW}${MATCHED_FILES}${NC}"
        echo -e "   This file should be in .gitignore"
        echo ""
        FOUND_SECRETS=$((FOUND_SECRETS + 1))
    fi
done

# ── 3. 结果判定 ──
if [ "$FOUND_SECRETS" -gt 0 ]; then
    echo -e "${RED}═══════════════════════════════════════════════════${NC}"
    echo -e "${RED}❌ Commit BLOCKED: ${FOUND_SECRETS} potential secret(s) found${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "To fix:"
    echo -e "  1. Remove the secret from staged files"
    echo -e "  2. Use placeholder values (e.g., 'your_api_key_here')"
    echo -e "  3. Add sensitive files to .gitignore"
    echo ""
    echo -e "${YELLOW}To bypass (ONLY if you're sure it's safe):${NC}"
    echo -e "  git commit --no-verify"
    echo ""
    exit 1
fi

echo -e "${GREEN}✅ No secrets detected. Commit allowed.${NC}"
exit 0
